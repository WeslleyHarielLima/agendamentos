generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StatusCompromisso {
  AGENDADO
  REALIZADO
  CANCELADO
}

enum Sexo {
  MASCULINO
  FEMININO
  OUTRO
}

model Paciente {
  id             String    @id @default(cuid())
  nome           String
  cpf            String?
  dataNascimento DateTime?
  sexo           Sexo?
  telefone       String
  email          String?
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  estado         String?
  observacoes    String?
  criadoEm       DateTime  @default(now())
  compromissos   Compromisso[]

  @@map("pacientes")
}

model Compromisso {
  id             String            @id @default(cuid())
  pacienteNome   String
  procedimento   String
  telefone       String
  descricao      String
  dataMarcacao   DateTime
  status         StatusCompromisso @default(AGENDADO)
  valorCobrado   Decimal?
  observacao     String?
  pacienteId     String?
  procedimentoId String?

  paciente        Paciente?    @relation(fields: [pacienteId], references: [id])
  procedimentoRel Procedimento? @relation(fields: [procedimentoId], references: [id])

  @@map("compromissos")
}

model Procedimento {
  id           String        @id @default(cuid())
  nome         String
  valor        Decimal
  descricao    String?
  ativo        Boolean       @default(true)
  criadoEm    DateTime      @default(now())
  compromissos Compromisso[]

  @@map("procedimentos")
}
