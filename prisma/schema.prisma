generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Compromisso {
  id           String   @id @default(cuid())
  pacienteNome String
  procedimento String
  telefone     String
  descricao    String
  dataMarcacao DateTime

  @@map("compromissos")
}

model Procedimento {
  id        String   @id @default(cuid())
  nome      String
  valor     Decimal
  descricao String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  @@map("procedimentos")
}
